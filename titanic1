import csv

# Global variables
records = []
headings = []


def load_data(file_path):
    global records
    global headings
    print("Loading data...", end="")
    try:
        with open(file_path, mode="r", encoding="utf-8") as file:
            csv_reader = csv.reader(file)
            headings = next(csv_reader)
            records = [row for row in csv_reader]
        print("Done!")
    except FileNotFoundError:
        print("\nError: File not found. Please check the path.")


def display_menu():
    """Displays the menu and returns the user's choice as an integer."""
    print("""
Please select one of the following options:
[1] Display the names of all passengers
[2] Display the number of passengers that survived
[3] Display the number of passengers per gender
[4] Display the number of passengers per age group""")

    # Read the response and convert to integer
    response = int(input())
    return response


def display_passenger_names():
    """Extracts and prints names from each record in the global list."""
    print("The names of the passengers are...")
    for record in records:
        # Assuming 'Name' is at index 3 in the titanic.csv
        passenger_name = record[3]
        print(passenger_name)


def run():
    path = "C:/Users/taluk/PycharmProjects/week11/titanic.csv"
    load_data(path)

    # Check if data was loaded before proceeding
    if records:
        num_records = len(records)
        print(f"Successfully loaded {num_records} records.")

        # Get menu selection
        selected_option = display_menu()
        print(f"You have selected option: {selected_option}")

        # Decision logic
        if selected_option == 1:
            display_passenger_names()
        else:
            print("Error! Option not recognised!")


if __name__ == "__main__":
    run()
