#survival history

import csv

# Global variables
records = []
headings = []


def load_data(file_path):
    global records
    global headings
    print("Loading data...", end="")
    try:
        with open(file_path, mode="r", encoding="utf-8") as file:
            csv_reader = csv.reader(file)
            headings = next(csv_reader)
            records = [row for row in csv_reader]
        print("Done!")
    except FileNotFoundError:
        print("\nError: File not found.")


def display_menu():
    print("""
Please select one of the following options:
[1] Display the names of all passengers
[2] Display the number of passengers that survived
[3] Display the number of passengers per gender
[4] Display the number of passengers per age group""")
    return int(input())


def display_passenger_names():
    print("The names of the passengers are...")
    for record in records:
        print(record[3])


def display_num_survivors():
    # Initialize the counter
    num_survived = 0

    for record in records:
        # Retrieve index 1 and convert to integer
        survival_status = int(record[1])

        # Check if the passenger survived (1 = Yes)
        if survival_status == 1:
            num_survived += 1

    print(f"{num_survived} passengers survived.")


def display_passengers_per_gender():
    females = 0
    males = 0
    for record in records:
        gender = record[4]
        if gender == "male":
            males += 1
        elif gender == "female":
            females += 1
    print(f"females: {females}, males: {males}")


def run():
    path = "C:/Users/taluk/PycharmProjects/week11/titanic.csv"
    load_data(path)

    if records:
        print(f"Successfully loaded {len(records)} records.")

        selected_option = display_menu()
        print(f"You have selected option: {selected_option}")

        # Updated decision logic to include option 2
        if selected_option == 1:
            display_passenger_names()
        elif selected_option == 2:
            display_num_survivors()
        elif selected_option == 3:
            display_passengers_per_gender()
        else:
            print("Error! Option not recognised!")


if __name__ == "__main__":
    run()
